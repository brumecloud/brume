BRUME_BASE_URL=http://localhost:8080
BRUME_API_PUBLIC_URL=http://localhost:8080
BRUME_AUTH_PUBLIC_URL=http://localhost:8080
BRUME_PLAN_PUBLIC_URL=http://localhost:8080
BRUME_PUBLIC_DOMAIN=localhost
# Production CLI URL: https://api.brume.dev
# Production OAuth URL: https://auth.brume.dev
# Production plan URL: https://plan.brume.dev
# Production wildcard domain: brume.dev
BRUME_BIND=[::]:8080
BRUME_DATABASE_URL=postgres://postgres:postgres@localhost:5432/brume
BRUME_STORAGE_BACKEND=filesystem
BRUME_STORAGE_PATH=.brume/storage
# For Railway Bucket storage, set BRUME_STORAGE_BACKEND=s3 and inject:
# AWS_ENDPOINT_URL, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
# AWS_S3_BUCKET_NAME, AWS_DEFAULT_REGION, AWS_S3_URL_STYLE
BRUME_GITHUB_CLIENT_ID=
BRUME_GITHUB_CLIENT_SECRET=
BRUME_GITHUB_ALLOWED_IDS=
