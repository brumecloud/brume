meta {
  name: Show plan
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/v1/plans/{{plan}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("plan exposes routes and retention", function() {
    expect(res.status).to.equal(200);
    expect(res.body.slug).to.equal(bru.getEnvVar("plan"));
    expect(res.body.routes).to.include("/");
    expect(res.body.expires_at).to.be.a("string");
  });
}

