meta {
  name: Unpin plan
  type: http
  seq: 7
}

patch {
  url: {{base_url}}/api/v1/plans/{{plan}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "pinned": false
  }
}

tests {
  test("unpinned plan gets an expiry", function() {
    expect(res.status).to.equal(200);
    expect(res.body.pinned).to.equal(false);
    expect(res.body.expires_at).to.be.a("string");
  });
}
