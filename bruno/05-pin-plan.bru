meta {
  name: Pin plan
  type: http
  seq: 6
}

patch {
  url: {{base_url}}/api/v1/plans/{{plan}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "pinned": true
  }
}

tests {
  test("pinned plan has no expiry", function() {
    expect(res.status).to.equal(200);
    expect(res.body.pinned).to.equal(true);
    expect(res.body.expires_at).to.equal(null);
  });
}
