meta {
  name: Make plan public
  type: http
  seq: 4
}

patch {
  url: {{base_url}}/api/v1/plans/{{plan}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "visibility": "public"
  }
}

tests {
  test("visibility is public", function() {
    expect(res.status).to.equal(200);
    expect(res.body.visibility).to.equal("public");
  });
}

